### TEST_REQUEST1

POST https://echo.kulala.app/post HTTP/1.1
Content-Type: application/json

{
  "kulalaFlavour": "cli"
}

> {%
  const { json } = response.body
  client.test("should return the same data", function() {
    client.assert(json.kulalaFlavour === "cli", `Expected kulalaFlavour to be 'cli', but got '${json.kulalaFlavour}'`);
  });
%}

### TEST_REQUEST2

POST https://echo.kulala.app/post HTTP/1.1
